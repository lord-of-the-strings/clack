# Maintainer: ThisWasAryan <https://github.com/ThisWasAryan>
# Maintainer: lord-of-the-strings <https://github.com/lord-of-the-strings>
pkgname=clack-gui-git
_pyname=clack-gui
pkgver=r2619a53
pkgrel=1
pkgdesc="A modern typing simulator with advanced humanization"
arch=('x86_64')
url="https://github.com/ThisWasAryan/clack"
license=('MIT')
depends=('python' 'python-gobject' 'gtk4' 'ydotool')
makedepends=('git' 'python-build' 'python-installer' 'python-setuptools' 'python-wheel' 'cargo' 'python-setuptools-rust')
provides=('clack-gui')
conflicts=('clack-gui')

source=("clack::git+${url}.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/clack"
  git describe --long --tags 2>/dev/null | sed 's/\([^-]*-\)*g/r/;s/-/./g' || echo "2.0.0.r$(git rev-list --count HEAD).g$(git rev-parse --short HEAD)"
}

build() {
  cd "${srcdir}/clack"
  python -m build --wheel --no-isolation
}

package() {
  cd "${srcdir}/clack"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 org.thiswasaryan.clack.desktop "$pkgdir/usr/share/applications/org.thiswasaryan.clack.desktop"
 install -Dm644 gui/assets/clack.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/org.thiswasaryan.clack.svg"
}
